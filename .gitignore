# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ─── Data — raw headlines are large and may contain copyrighted content ───────
data/raw/
data/external/

# Keep processed feature matrix in git (small, no copyright issues)
!data/processed/wsj_market_features.csv
!data/processed/.gitkeep

# ─── Scraper state files ──────────────────────────────────────────────────────
wsj_checkpoint.json
wsj_headlines.xlsx

# ─── Model artifacts (can be large) ──────────────────────────────────────────
models/
*.pkl
*.joblib
*.h5
*.pt
*.pth

# ─── Hugging Face cache ───────────────────────────────────────────────────────
.cache/
~/.cache/huggingface/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Environment variables / secrets ─────────────────────────────────────────
.env
.env.*
secrets.yaml

# ─── Logs & temp ─────────────────────────────────────────────────────────────
logs/
*.log
tmp/
temp/

# ─── Reports — keep figures but not large generated notebooks ────────────────
reports/figures/*.png
reports/figures/*.pdf
!reports/figures/.gitkeep
